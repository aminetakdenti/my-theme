{
  "$schema": "vscode://schemas/color-theme",
  "name": "Onyx Light",
  "type": "light",
  "colors": {
    "editor.background": "#eeeeee",
    "editor.foreground": "#333333",
    "editor.lineHighlightBackground": "#33333310",
    "editor.selectionBackground": "#c9a22720",
    "editor.inactiveSelectionBackground": "#33333310",
    "editor.findMatchBackground": "#c9a22720",
    "editor.findMatchHighlightBackground": "#c9a22715",
    "editorLineNumber.foreground": "#33333360",
    "editorLineNumber.activeForeground": "#333333",
    "editorCursor.foreground": "#9a7a0a",
    "editorWhitespace.foreground": "#33333310",
    "editorIndentGuide.background1": "#33333310",
    "editorIndentGuide.activeBackground1": "#33333330",
    "editorRuler.foreground": "#33333310",
    "editorBracketMatch.background": "#33333310",
    "editorBracketMatch.border": "#33333330",
    "editorOverviewRuler.border": "#33333310",
    "editorOverviewRuler.errorForeground": "#eb5757",
    "editorOverviewRuler.warningForeground": "#9a7a0a",
    "editorOverviewRuler.infoForeground": "#9a7a0a",
    "editorGutter.background": "#eeeeee",
    "editorGutter.addedBackground": "#00933f",
    "editorGutter.modifiedBackground": "#333333",
    "editorGutter.deletedBackground": "#eb5757",
    "editorError.foreground": "#eb5757",
    "editorWarning.foreground": "#9a7a0a",
    "editorInfo.foreground": "#9a7a0a",

    "activityBar.background": "#eeeeee",
    "activityBar.foreground": "#333333",
    "activityBar.inactiveForeground": "#777777",
    "activityBar.border": "#33333330",
    "activityBarBadge.background": "#9a7a0a",
    "activityBarBadge.foreground": "#eeeeee",

    "sideBar.background": "#eeeeee",
    "sideBar.foreground": "#333333",
    "sideBar.border": "#33333330",
    "sideBarTitle.foreground": "#777777",
    "sideBarSectionHeader.background": "#eeeeee",
    "sideBarSectionHeader.foreground": "#777777",
    "sideBarSectionHeader.border": "#33333310",

    "list.activeSelectionBackground": "#33333310",
    "list.activeSelectionForeground": "#333333",
    "list.inactiveSelectionBackground": "#33333310",
    "list.inactiveSelectionForeground": "#333333",
    "list.hoverBackground": "#33333310",
    "list.hoverForeground": "#333333",
    "list.focusBackground": "#33333310",
    "list.focusForeground": "#333333",
    "listFilterWidget.background": "#f2f2f2",
    "listFilterWidget.outline": "#33333310",
    "listFilterWidget.noMatchesOutline": "#eb5757",

    "statusBar.background": "#eeeeee",
    "statusBar.foreground": "#777777",
    "statusBar.border": "#33333330",
    "statusBar.noFolderBackground": "#eeeeee",
    "statusBar.debuggingBackground": "#eeeeee",
    "statusBarItem.hoverBackground": "#33333310",
    "statusBarItem.activeBackground": "#33333310",
    "statusBarItem.prominentBackground": "#f2f2f2",

    "titleBar.activeBackground": "#eeeeee",
    "titleBar.activeForeground": "#333333",
    "titleBar.inactiveBackground": "#eeeeee",
    "titleBar.inactiveForeground": "#777777",
    "titleBar.border": "#33333330",

    "tab.activeBackground": "#eeeeee",
    "tab.activeForeground": "#333333",
    "tab.inactiveBackground": "#eeeeee",
    "tab.inactiveForeground": "#777777",
    "tab.border": "#33333310",
    "tab.activeBorder": "#9a7a0a",
    "tab.hoverBackground": "#33333310",
    "editorGroupHeader.tabsBackground": "#eeeeee",
    "editorGroupHeader.tabsBorder": "#33333310",
    "editorGroup.border": "#33333310",

    "panel.background": "#eeeeee",
    "panel.border": "#33333330",
    "panelTitle.activeBorder": "#9a7a0a",
    "panelTitle.activeForeground": "#333333",
    "panelTitle.inactiveForeground": "#777777",

    "terminal.background": "#eeeeee",
    "terminal.foreground": "#333333",
    "terminalCursor.foreground": "#9a7a0a",
    "terminal.ansiBlack": "#333333",
    "terminal.ansiBrightBlack": "#666666",
    "terminal.ansiRed": "#eb5757",
    "terminal.ansiBrightRed": "#eb5757",
    "terminal.ansiGreen": "#00933f",
    "terminal.ansiBrightGreen": "#00933f",
    "terminal.ansiYellow": "#9a7a0a",
    "terminal.ansiBrightYellow": "#9a7a0a",
    "terminal.ansiBlue": "#9a7a0a",
    "terminal.ansiBrightBlue": "#9a7a0a",
    "terminal.ansiMagenta": "#eb5757",
    "terminal.ansiBrightMagenta": "#eb5757",
    "terminal.ansiCyan": "#00933f",
    "terminal.ansiBrightCyan": "#00933f",
    "terminal.ansiWhite": "#eeeeee",
    "terminal.ansiBrightWhite": "#ffffff",

    "input.background": "#f2f2f2",
    "input.foreground": "#333333",
    "input.border": "#33333310",
    "input.placeholderForeground": "#888888",
    "inputOption.activeBorder": "#9a7a0a",
    "inputOption.activeBackground": "#c9a22715",
    "inputValidation.errorBackground": "#f2f2f2",
    "inputValidation.errorBorder": "#eb5757",

    "button.background": "#9a7a0a",
    "button.foreground": "#eeeeee",
    "button.hoverBackground": "#9a7a0acc",
    "button.secondaryBackground": "#f2f2f2",
    "button.secondaryForeground": "#333333",

    "dropdown.background": "#f2f2f2",
    "dropdown.foreground": "#333333",
    "dropdown.border": "#33333310",

    "focusBorder": "#9a7a0a",
    "foreground": "#333333",
    "disabledForeground": "#999999",
    "descriptionForeground": "#777777",
    "errorForeground": "#eb5757",
    "textLink.foreground": "#9a7a0a",
    "textLink.activeForeground": "#9a7a0a",
    "selection.background": "#c9a22720",
    "widget.shadow": "#33333320",

    "scrollbar.shadow": "#33333320",
    "scrollbarSlider.background": "#33333340",
    "scrollbarSlider.hoverBackground": "#33333330",
    "scrollbarSlider.activeBackground": "#33333350",

    "progressBar.background": "#9a7a0a",

    "badge.background": "#9a7a0a",
    "badge.foreground": "#eeeeee",

    "notifications.background": "#f2f2f2",
    "notifications.foreground": "#333333",
    "notifications.border": "#33333310",
    "notificationLink.foreground": "#9a7a0a",

    "gitDecoration.addedResourceForeground": "#00933f",
    "gitDecoration.modifiedResourceForeground": "#333333",
    "gitDecoration.deletedResourceForeground": "#eb5757",
    "gitDecoration.untrackedResourceForeground": "#00933f",
    "gitDecoration.ignoredResourceForeground": "#888888",
    "gitDecoration.conflictingResourceForeground": "#9a7a0a",

    "diffEditor.insertedTextBackground": "#00933f20",
    "diffEditor.removedTextBackground": "#eb575720",
    "diffEditor.insertedLineBackground": "#00933f10",
    "diffEditor.removedLineBackground": "#eb575710",

    "breadcrumb.foreground": "#777777",
    "breadcrumb.focusForeground": "#333333",
    "breadcrumbPicker.background": "#f2f2f2",

    "menu.background": "#f2f2f2",
    "menu.foreground": "#333333",
    "menu.selectionBackground": "#33333310",
    "menu.selectionForeground": "#333333",
    "menu.separatorBackground": "#33333310",
    "menu.border": "#33333310",
    "menubar.selectionBackground": "#33333310",
    "menubar.selectionForeground": "#333333",

    "quickInput.background": "#f2f2f2",
    "quickInput.foreground": "#333333",
    "quickInputHighlight.background": "#c9a22720",

    "peekView.border": "#33333310",
    "peekViewEditor.background": "#eeeeee",
    "peekViewEditorGutter.background": "#eeeeee",
    "peekViewResult.background": "#f2f2f2",
    "peekViewResult.selectionBackground": "#33333310",
    "peekViewResult.selectionForeground": "#333333",
    "peekViewTitle.background": "#f2f2f2",
    "peekViewTitleDescription.foreground": "#777777",
    "peekViewTitleLabel.foreground": "#333333"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#999999" }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#666666" }
    },
    {
      "scope": ["constant", "constant.numeric", "constant.language", "constant.character"],
      "settings": { "foreground": "#9a7a0a" }
    },
    {
      "scope": ["keyword", "keyword.control", "keyword.operator", "storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#9a7a0a" }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call entity.name.function"],
      "settings": { "foreground": "#9a7a0a", "fontStyle": "bold" }
    },
    {
      "scope": ["variable", "variable.other", "meta.object-literal.key"],
      "settings": { "foreground": "#333333" }
    },
    {
      "scope": ["variable.other.property", "support.variable.property", "meta.property-name"],
      "settings": { "foreground": "#333333" }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.class"],
      "settings": { "foreground": "#333333" }
    },
    {
      "scope": ["entity.name.tag", "support.class.component"],
      "settings": { "foreground": "#888888" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#888888" }
    },
    {
      "scope": ["punctuation", "meta.brace", "meta.delimiter"],
      "settings": { "foreground": "#888888" }
    },
    {
      "scope": ["support.type", "support.constant"],
      "settings": { "foreground": "#888888" }
    },
    {
      "scope": ["variable.parameter", "meta.parameter"],
      "settings": { "foreground": "#888888" }
    },
    {
      "scope": ["markup.heading"],
      "settings": { "foreground": "#333333", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "foreground": "#333333", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "foreground": "#333333", "fontStyle": "italic" }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#666666" }
    },
    {
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#00933f" }
    },
    {
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#eb5757" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#eb5757" }
    }
  ]
}
